# ── Docker / environment variables ──────────────────────────────────────────
# Copy to .env and adjust before running docker compose

# PostgreSQL
POSTGRES_DB=jobhoppr
POSTGRES_USER=jobhoppr
POSTGRES_PASSWORD=jobhoppr_secret

# Spring Boot datasource (used inside the backend container)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/jobhoppr
SPRING_DATASOURCE_USERNAME=jobhoppr
SPRING_DATASOURCE_PASSWORD=jobhoppr_secret

# Active Spring profile (add "dev" to generate test data)
SPRING_PROFILES_ACTIVE=prod
